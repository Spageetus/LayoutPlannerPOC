@using System.IO
@using System.Text
@inject IJSRuntime JSRuntime

<label class="load-files-label" @onclick="DownloadFileFromStream">
    <img class="download-icon" src="/Assets/Icons/download-01-stroke-rounded.svg" />
</label>

<script>
    window.downloadFileFromStream = async (fileName, contentStreamReference) => {
      const arrayBuffer = await contentStreamReference.arrayBuffer();
      const blob = new Blob([arrayBuffer]);
      const url = URL.createObjectURL(blob);
      const anchorElement = document.createElement('a');
      anchorElement.href = url;
      anchorElement.download = fileName ?? '';
      anchorElement.click();
      anchorElement.remove();
      URL.revokeObjectURL(url);
    }
</script>

@code {
    private void Test()
    {
        Console.WriteLine("Clicked download button");
    }

    private Stream GetFileStream()
    {

        string data = StateManager.GetComponentsListAsJSON();
        var bytes = Encoding.UTF8.GetBytes(data);
        var stream = new MemoryStream(bytes);
        return stream;
    }

    private async Task DownloadFileFromStream()
    {
        var fileStream = GetFileStream();
        var fileName = "layout.json";

        using var streamRef = new DotNetStreamReference(stream: fileStream);
        await JSRuntime.InvokeVoidAsync("downloadFileFromStream", fileName, streamRef);
    }
}