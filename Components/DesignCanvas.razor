@inject IJSRuntime JSRuntime

<canvas @ref="_canvasReference" @onclick="HandleCanvasClick" @onmousemove="HandleMouseMove"@ id="design-canvas" tabindex="0" @oncontextmenu:preventDefault="true">I am the main canvas</canvas>
@code {


    private ElementReference _canvasReference;

    private int cellSize = 20;


    private double _clickX;
    private double _clickY;
    private double _mouseRow;
    private double _mouseCol;

    //TODO: Is this something the StateManager should remember???
    //TODO: Rename to canvasOffsetX/Y
    private static double canvasTop = 0; //making these variables static so I can set them using the JSInvokeable functions
    private static double canvasLeft = 0;

    //sets up canvas for the first time (if necessary), then draws canvas
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("canvasInterop.setupCanvas", _canvasReference, cellSize);
            await Redraw();
        }
    }



    protected async Task Redraw()
    {
        await JSRuntime.InvokeVoidAsync("canvasInterop.redraw");
        canvasTop = await JSRuntime.InvokeAsync<float>("canvasInterop.getCanvasTop");
        canvasLeft = await JSRuntime.InvokeAsync<float>("canvasInterop.getCanvasLeft");
    }

    private async Task HandleCanvasClick(MouseEventArgs e)
    {
        Console.WriteLine("Placing component: " + StateManager.GetSelectedComponentType());
        string componentName = StateManager.GetSelectedComponentType();

        Data.FactoryComponent? c = Data.FactoryComponent.CreateFromName(componentName);
        if (c is null) return;

        double canvasClickX = e.OffsetX + canvasLeft;
        if (canvasClickX < 0) canvasClickX -= cellSize; //slight adjustment to fix offset for clicks where x < 0
        double canvasClickY = e.OffsetY + canvasTop;
        if (canvasClickY < 0) canvasClickY -= cellSize; //slight adjustment to fix offset for clicks where y < 0

        _clickX = Math.Truncate(canvasClickX / cellSize);
        _clickY = Math.Truncate(canvasClickY/ cellSize);


        c.SetLocation((int)_clickX, (int)_clickY);

        //await JSRuntime.InvokeVoidAsync("canvasInterop.resetTransform");

        await JSRuntime.InvokeVoidAsync("canvasInterop.addComponent", c);
        await Redraw();
    }

    private async Task HandleMouseMove(MouseEventArgs e)
    {
        double canvasY = e.OffsetY + canvasTop;
        if (canvasY < 0) canvasY -= cellSize;
        double canvasX = e.OffsetX + canvasLeft;
        if (canvasX < 0) canvasX -= cellSize;
        _mouseRow = Math.Truncate(canvasY / cellSize);
        _mouseCol = Math.Truncate(canvasX / cellSize);

        if (StateManager.GetHeldComponent() is not null)
        {
            LayoutPlannerPOC.Data.FactoryComponent c = StateManager.GetHeldComponent();
            if(c.X != (int)_mouseCol || c.Y != (int)_mouseRow)
            {
                c.SetLocation((int)_mouseCol, (int)_mouseRow);
                Console.WriteLine("Held Component: " + StateManager.GetHeldComponent().Name);
                await JSRuntime.InvokeVoidAsync("canvasInterop.setHeldComponent", c);
                await this.Redraw();
            }
        }
    }

}
